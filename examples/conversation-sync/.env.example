# Backend
BACKEND_PRIVATE_KEY=0x...  # Generate: bun run generate-key
TINYCLOUD_HOST=https://node.tinycloud.xyz
FRONTEND_URL=https://localhost:5173
PORT=3001

# Agents feature (task #5)
# Required for /api/agents/:id/messages. Shared across all agents.
# Set either ANTHROPIC_API_KEY or CLAUDE_API_KEY.
ANTHROPIC_API_KEY=

# Frontend (Vite)
VITE_OPENKEY_HOST=https://openkey.so
VITE_TINYCLOUD_HOST=https://node.tinycloud.xyz
VITE_BACKEND_URL=http://localhost:3001

# Note: Fireflies API key is per-user, stored in TinyCloud KV
# (no environment variable needed)
