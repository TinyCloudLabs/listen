{
  "id": "com.tinyboilerplate.react-express",
  "name": "TinyBoilerplate (React + Express example)",
  "description": "React frontend + Express backend demo for TinyCloud + OpenKey.",
  "prefix": "",
  "defaults": false,
  "permissions": [
    {
      "service": "tinycloud.kv",
      "space": "default",
      "path": "",
      "actions": ["get", "put", "del", "list", "metadata"]
    },
    {
      "service": "tinycloud.sql",
      "space": "default",
      "path": "",
      "actions": ["read", "write"]
    },
    {
      "service": "tinycloud.duckdb",
      "space": "default",
      "path": "",
      "actions": ["read", "write"]
    },
    {
      "service": "tinycloud.capabilities",
      "space": "default",
      "path": "",
      "actions": ["read"]
    }
  ]
}
