{
  "name": "tinyboilerplate",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "examples/react-express/frontend",
    "examples/react-express/backend",
    "examples/conversation-sync/frontend",
    "examples/conversation-sync/backend"
  ],
  "overrides": {
    "@tinycloud/sdk-core": "2.1.0-beta.2",
    "@tinycloud/sdk-services": "2.1.0-beta.1",
    "@tinycloud/web-core": "1.7.0",
    "@tinycloud/node-sdk-wasm": "1.7.2-beta.2"
  },
  "scripts": {
    "build": "turbo run build",
    "predev": "lsof -ti:3001,5173 | xargs kill -9 2>/dev/null; pkill -9 -f 'bun --watch src/index.ts' 2>/dev/null; true",
    "dev": "turbo run dev --filter=@tinyboilerplate/example-frontend --filter=@tinyboilerplate/example-backend",
    "dev:conversation-sync": "turbo run dev --filter=conversation-sync-frontend --filter=conversation-sync-backend",
    "generate-key": "cd packages/server && bun run generate-key",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tinycloud/node-sdk": "2.1.0-beta.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.57.1"
  }
}
