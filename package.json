{
  "name": "listen",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "frontend",
    "backend",
    "test"
  ],
  "overrides": {
    "@tinycloud/sdk-core": "2.2.0-beta.12",
    "@tinycloud/sdk-services": "2.2.0-beta.12",
    "@tinycloud/web-sdk": "2.2.0-beta.12",
    "@tinycloud/node-sdk": "2.2.0-beta.12",
    "@tinycloud/web-core": "1.7.0",
    "@tinycloud/node-sdk-wasm": "1.7.3-beta.1",
    "@tinycloud/web-sdk-wasm": "1.7.3-beta.1"
  },
  "scripts": {
    "build": "bun install --frozen-lockfile && bunx turbo run build",
    "start": "bun run --cwd backend start",
    "predev": "lsof -ti:3001,5173 | xargs kill -9 2>/dev/null; pkill -9 -f 'bun --watch src/index.ts' 2>/dev/null; true",
    "dev": "bun run dev:portless",
    "dev:localhost": "bun run dev:backend & bun run dev:frontend",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "cd backend && bun --env-file=../.env run dev",
    "dev:portless": "bun run dev:portless:backend & bun run dev:portless:frontend",
    "dev:portless:frontend": "cd frontend && VITE_BACKEND_URL=https://api.listen.localhost bun run dev:portless",
    "dev:portless:backend": "cd backend && FRONTEND_URL=https://listen.localhost bun --env-file=../.env run dev:portless",
    "generate-key": "cd packages/server && bun run generate-key",
    "test": "turbo run test",
    "test:app:install": "bun run --cwd test install:browsers",
    "test:app:install:ci": "bun run --cwd test install:browsers:ci",
    "test:app": "bunx turbo run build --filter=@listen/client... && bun run --cwd test app:smoke",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:backend:build": "docker buildx build --platform linux/amd64 -f backend/Dockerfile -t ${LISTEN_BACKEND_IMAGE:-ghcr.io/tinycloudlabs/listen-backend:latest} .",
    "docker:backend:push": "docker buildx build --platform linux/amd64 -f backend/Dockerfile -t ${LISTEN_BACKEND_IMAGE:-ghcr.io/tinycloudlabs/listen-backend:latest} --push .",
    "deploy:frontend": "bun run build --filter=listen-frontend && CLOUDFLARE_ACCOUNT_ID=9959301f03d2db1a5fcf5e004278d467 bunx wrangler pages deploy",
    "deploy:backend:phala": "phala deploy --cvm-id 5b6391f2-9e81-4331-baa7-162a5d9838da -c docker-compose.phala.yml -e .env.prod -e LISTEN_BACKEND_IMAGE=${LISTEN_BACKEND_IMAGE:-ghcr.io/tinycloudlabs/listen-backend:latest} -e PORT=3001 --wait",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tinycloud/node-sdk": "2.2.0-beta.12",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "portless": "^0.13.0",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.57.1"
  }
}
