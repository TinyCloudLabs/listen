{
  "name": "listen-e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun run test:m1-owner",
    "test:m1-owner": "vitest run --config vitest.config.ts m1-owner-demo.test.ts",
    "setup": "bun setup-passkey.ts",
    "signin": "bun run-signin.ts",
    "install:browsers": "playwright install chromium",
    "install:browsers:ci": "playwright install --with-deps chromium",
    "app:smoke": "playwright test",
    "hooks:e2e": "playwright test --config playwright.hooks.config.ts",
    "recovery:e2e": "playwright test --config playwright.recovery.config.ts"
  },
  "dependencies": {
    "@listen/client": "workspace:*",
    "@tinycloud/node-sdk": "2.8.0",
    "@playwright/test": "^1.50.0",
    "playwright": "^1.50.0",
    "multiformats": "^13.4.1"
  },
  "devDependencies": {
    "@tinycloud/bootstrap-m1": "npm:@tinycloud/bootstrap@2.5.0",
    "@tinycloud/node-sdk-m1": "file:./vendor/tinycloud-node-sdk-m1",
    "@tinycloud/sdk-core-m1": "file:./vendor/tinycloud-sdk-core-m1",
    "@tinycloud/sdk-services-m1": "npm:@tinycloud/sdk-services@2.6.0",
    "vitest": "^4.1.1"
  }
}
