{
  "name": "listen-e2e",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun run test:m1-owner",
    "test:m1-owner": "vitest run --config vitest.config.ts m1-owner-demo.test.ts",
    "setup": "bun setup-passkey.ts",
    "signin": "bun run-signin.ts",
    "install:browsers": "playwright install chromium",
    "install:browsers:ci": "playwright install --with-deps chromium",
    "app:smoke": "playwright test",
    "hooks:e2e": "playwright test --config playwright.hooks.config.ts"
  },
  "dependencies": {
    "@listen/client": "workspace:*",
    "@tinycloud/node-sdk": "2.4.0",
    "@playwright/test": "^1.50.0",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "vitest": "^4.1.1"
  }
}
