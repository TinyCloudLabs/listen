# Backend
BACKEND_PRIVATE_KEY=0x...  # Generate: bun run generate-key
# Optional backend TinyCloud node override
# TINYCLOUD_HOST=https://node.tinycloud.xyz
FRONTEND_URL=https://listen.localhost
PORT=3001

# Frontend (Vite)
VITE_OPENKEY_HOST=https://openkey.so
VITE_BACKEND_URL=https://api.listen.localhost
VITE_ENABLE_TINYCLOUD_HOOKS=false
VITE_ENABLE_AGENT=false
VITE_AGENT_ENDPOINT=http://localhost:4097

# Production defaults used for Cloudflare Pages / Phala examples:
# FRONTEND_URL=https://listen.tinycloud.xyz
# VITE_BACKEND_URL=https://api.listen.tinycloud.xyz
# VITE_ENABLE_AGENT=false

# Note: Fireflies API key is per-user, stored in TinyCloud KV
# (no environment variable needed)

# listen-agent Docker container (TC-1344)
OPENCODE_ZEN_API_KEY=sk-...  # get from https://opencode.ai/zen
