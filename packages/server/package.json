{
  "name": "@listen/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run --cwd ../core build && tsc",
    "dev": "tsc --watch",
    "test": "bun run --cwd ../core build && bun run --cwd ../client build && bun test",
    "generate-key": "bun run scripts/generate-key.ts",
    "postinstall": "node scripts/fix-wasm-esm.mjs"
  },
  "dependencies": {
    "@listen/core": "workspace:*",
    "@tinycloud/node-sdk": "2.8.0",
    "jose": "^5.0.0",
    "siwe": "^2.3.2"
  },
  "devDependencies": {
    "@listen/client": "workspace:*",
    "@types/express": "^4.17.0",
    "express": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
