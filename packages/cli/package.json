{
  "name": "@tinyboilerplate/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "listen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:binary": "bun build src/index.ts --compile --outfile dist/listen",
    "build:binary:linux-x64": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/listen-linux-x64",
    "build:binary:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/listen-linux-arm64",
    "build:binary:darwin-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/listen-darwin-x64",
    "build:binary:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/listen-darwin-arm64",
    "build:all-targets": "bun run build:binary:linux-x64 && bun run build:binary:linux-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:darwin-arm64",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "postinstall": "node ../server/scripts/fix-wasm-esm.mjs"
  },
  "dependencies": {
    "@tinyboilerplate/core": "workspace:*",
    "@tinycloud/node-sdk": "2.1.0-beta.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
